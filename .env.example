# Create a .env file in the project root and set your Google Form settings.
# ACTION URL example:
# https://docs.google.com/forms/d/e/yourFormId/formResponse
VITE_GOOGLE_FORM_ACTION_URL=

# entry keys come from your Google Form source, examples:
# entry.123456789
VITE_GOOGLE_FORM_ENTRY_NAME=
VITE_GOOGLE_FORM_ENTRY_EMAIL=
VITE_GOOGLE_FORM_ENTRY_MESSAGE=
